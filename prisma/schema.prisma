// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RecipeCategory {
  bread
  dessert
  drink
  main
  sauce
  other
}

enum IngredientRole {
  flour
  liquid
  preferment
  salt
  sweetener
  fat
  add_in
  spice
  other
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  recipes  Recipe[]
  sessions Session[]
  accounts Account[]
}

model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Account {
  id                String   @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
}

model Recipe {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  category        RecipeCategory
  description     String?
  tags            Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  activeVersionId String?           @unique
  activeVersion   RecipeVersion?    @relation("ActiveRecipeVersion", fields: [activeVersionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  versions        RecipeVersion[]

  @@index([userId])
}

model RecipeVersion {
  id            String         @id @default(cuid())
  recipeId      String
  recipe        Recipe         @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeActive  Recipe?        @relation("ActiveRecipeVersion")
  title         String         @default("")
  notes         String         @default("")
  tastingNotes  String         @default("")
  nextSteps     String         @default("")
  metadata      Json?
  photoUrl      String?
  tasteRating   Int?
  visualRating  Int?
  textureRating Int?
  tasteTags     String[]       @default([])
  textureTags   String[]       @default([])
  iterationIntent String?
  hypothesis    String?
  outcome       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  ingredients   Ingredient[]
}

model Ingredient {
  id         String          @id @default(cuid())
  versionId  String
  version    RecipeVersion   @relation(fields: [versionId], references: [id], onDelete: Cascade)
  name       String
  quantity   Float
  unit       String
  role       IngredientRole
  notes      String?
  sortOrder  Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}
